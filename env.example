# Database
DATABASE_URL="your_database_connection_string_here"

# API Keys
ADMIN_API_KEYS_ENCRYPTION_KEY=your_32_byte_encryption_key_here
USER_API_TOKENS_ENCRYPTION_KEY=your_32_byte_user_token_encryption_key_here

# modelslab api key
MODELSLAB_API_KEY=your_modelslab_api_key_here
MODELSLAB_BASE_URL=https://modelslab.com

# api base url
API_BASE_URL=http://localhost:3000/api
TEST_API_KEY=ptr_test_1234567890abcdef

# PayPal Configuration
PAYPAL_TEST=true
PAYPAL_CLIENT_ID_SANDBOX=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET_SANDBOX=your_paypal_sandbox_client_secret
PAYPAL_CLIENT_ID_LIVE="your_paypal_live_client_id"
PAYPAL_CLIENT_SECRET_LIVE=your_paypal_live_client_secret

# PayPal Webhook URLs (optional)
PAYPAL_WEBHOOK_ID_SANDBOX=your_paypal_sandbox_webhook_id
PAYPAL_WEBHOOK_ID_LIVE=your_paypal_live_webhook_id

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key_here
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key_here
PAYSTACK_CURRENCY=USD
PAYSTACK_USD_TO_CHARGE_RATE=1

# Public app URL (used for PayPal/Paystack redirect URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=supabase_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
